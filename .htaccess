Options +FollowSymlinks
RewriteEngine On

# Ne pas réécrire si le fichier ou le dossier existe
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Page d'accueil
RewriteRule ^$ index.php [L]

# Liste des articles (compatibilité existante)
RewriteRule ^articles/?$ frontend/articles-list.php [L,QSA]

# Détail article URL propre
RewriteRule ^article/([a-z0-9\-]+)/?$ article.php?slug=$1 [L,QSA]

# Catégorie (si utilisée)
RewriteRule ^categorie/([a-z0-9\-]+)/?$ categorie.php?slug=$1 [L,QSA]

# Compatibilité : ancien schéma /articles/{slug}
RewriteRule ^articles/([^/]+)/?$ frontend/article-detail.php?slug=$1 [L,QSA]

# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
